{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/vt-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types ../../scripts/portless-dev.ts vt.osmix node --watch server.ts",
    "dev:app": "node --watch server.ts",
    "start": "node server.ts",
    "test": "node --experimental-strip-types test/server.test.ts",
    "typecheck": "tsc --build --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@osmix/core": "workspace:*",
    "@osmix/types": "workspace:*",
    "@osmix/vt": "workspace:*",
    "comlink": "^4.4.2",
    "hono": "^4.8.3",
    "maplibre-gl": "catalog:",
    "osmix": "workspace:*"
  },
  "devDependencies": {
    "@osmix/json": "workspace:*",
    "@osmix/pbf": "workspace:*",
    "@osmix/shared": "workspace:*",
    "typescript": "catalog:"
  }
}
