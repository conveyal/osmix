{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check": "oxfmt . && oxlint --type-aware --fix --fix-dangerously",
    "clean": "rm -rf packages/*/dist apps/*/dist node_modules packages/*/node_modules apps/*/node_modules packages/*/*.tgz",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --fix --fix-dangerously",
    "lint:check": "oxlint --type-aware",
    "test": "vitest run",
    "test:all": "pnpm run typecheck && pnpm run check && VITEST_INCLUDE_APPS=1 vitest run",
    "test:apps": "VITEST_INCLUDE_APPS=1 vitest run '--project=@osmix/merge' '--project=@osmix/bench*'",
    "test:node-smoke": "node scripts/node-smoke.ts",
    "test:check-docs": "node --experimental-strip-types scripts/check-docs.test.ts",
    "test:packages": "vitest run",
    "test:verify-workspace": "node --experimental-strip-types scripts/verify-workspace.test.ts",
    "verify:all": "node --experimental-strip-types scripts/verify-workspace.ts --all",
    "verify:workspace": "node --experimental-strip-types scripts/verify-workspace.ts",
    "check:docs": "node --experimental-strip-types scripts/check-docs.ts",
    "check:deps": "node scripts/check-deps.ts",
    "typecheck": "pnpm -r typecheck",
    "version": "changeset version && pnpm install",
    "release": "node scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "catalog:",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.10.0"
}
