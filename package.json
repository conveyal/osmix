{
	"$schema": "https://json.schemastore.org/package.json",
	"packageManager": "bun@1.3.14",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@placemarkio/geojson-rewind": "^1.0.3",
			"@types/bun": "^1.3.14",
			"@types/geojson": "^7946.0.16",
			"dequal": "^2.0.3",
			"maplibre-gl": "^5.24.0",
			"pbf": "^5.1.0",
			"typescript": "npm:typescript@rc",
			"vite": "^8.1.3"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@changesets/cli": "^2.31.0",
		"typescript": "npm:typescript@rc"
	},
	"scripts": {
		"dev": "bun --filter '*' dev",
		"build": "bun --filter '*' build",
		"check": "biome check --write .",
		"clean": "rm -rf packages/*/dist apps/*/dist node_modules packages/*/node_modules apps/*/node_modules packages/*/*.tgz",
		"format": "biome format --write .",
		"lint": "biome lint --write --unsafe .",
		"test": "bun run test:packages",
		"test:all": "bun run typecheck && bun run lint && bun run check && bun run test:packages && bun run test:apps",
		"test:apps": "bun --filter './apps/**' test --silent",
		"test:node-smoke": "bun scripts/node-smoke.ts",
		"test:packages": "bun --filter './packages/**' test --silent",
		"typecheck": "bun --filter '*' typecheck",
		"version": "changeset version && bun update",
		"release": "bun scripts/release.ts"
	},
	"trustedDependencies": [
		"@tailwindcss/oxide"
	]
}
