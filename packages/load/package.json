{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/load",
  "version": "0.0.1",
  "description": "Load and export OSM data from PBF into Osm indexes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@osmix/core": "workspace:*",
    "@osmix/json": "workspace:*",
    "@osmix/pbf": "workspace:*",
    "@osmix/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
