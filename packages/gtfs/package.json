{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@osmix/gtfs",
	"description": "Convert GTFS transit feeds to OSM format.",
	"version": "0.0.10",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/conveyal/osmix.git"
	},
	"main": "./src/index.ts",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"bench": "vitest bench",
		"test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"fflate": "^0.8.3",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@osmix/core": "workspace:*",
		"@osmix/shared": "workspace:*",
		"but-unzip": "^0.1.10"
	}
}
