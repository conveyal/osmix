{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/change",
  "version": "0.1.9",
  "description": "An OSM changeset generator and merger built on top of @osmix/core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bench": "vitest bench",
    "test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@osmix/core": "workspace:*",
    "@osmix/shared": "workspace:*",
    "dequal": "catalog:",
    "sweepline-intersections": "^2.0.1"
  },
  "devDependencies": {
    "@types/geojson": "catalog:",
    "typescript": "catalog:"
  }
}
