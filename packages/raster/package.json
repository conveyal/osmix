{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/raster",
  "version": "0.1.0",
  "description": "An OSM raster tile generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bench": "vitest bench",
    "test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@osmix/geo": "workspace:*",
    "@osmix/types": "workspace:*",
    "@placemarkio/geojson-rewind": "catalog:"
  },
  "devDependencies": {
    "@osmix/shared": "workspace:*",
    "@types/geojson": "catalog:",
    "typescript": "catalog:"
  }
}
