{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "osmix",
  "version": "0.3.0",
  "description": "Full OSM toolkit for JavaScript and TypeScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/osmix.worker.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@osmix/change": "workspace:*",
    "@osmix/core": "workspace:*",
    "@osmix/geo": "workspace:*",
    "@osmix/geojson": "workspace:*",
    "@osmix/geoparquet": "workspace:*",
    "@osmix/gtfs": "workspace:*",
    "@osmix/json": "workspace:*",
    "@osmix/load": "workspace:*",
    "@osmix/pbf": "workspace:*",
    "@osmix/raster": "workspace:*",
    "@osmix/router": "workspace:*",
    "@osmix/shapefile": "workspace:*",
    "@osmix/shared": "workspace:*",
    "@osmix/types": "workspace:*",
    "@osmix/vt": "workspace:*",
    "comlink": "^4.4.2",
    "dequal": "catalog:"
  },
  "devDependencies": {
    "@mapbox/tilebelt": "^2.0.3",
    "@osmix/test-utils": "workspace:*",
    "@types/geojson": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  }
}
