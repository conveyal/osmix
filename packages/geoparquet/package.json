{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/geoparquet",
  "version": "0.1.11",
  "description": "Import OSM data from GeoParquet files.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bench": "vitest bench",
    "test": "pnpm -w exec vitest run --project \"$npm_package_name\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@osmix/core": "workspace:*",
    "@osmix/shared": "workspace:*",
    "@osmix/types": "workspace:*",
    "@placemarkio/geojson-rewind": "catalog:",
    "hyparquet": "^1.26.2"
  },
  "devDependencies": {
    "@osmix/test-utils": "workspace:*",
    "@types/geojson": "catalog:",
    "typescript": "catalog:"
  }
}
