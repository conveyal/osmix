{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@osmix/test-utils",
  "version": "0.0.1",
  "description": "Test fixtures and helpers for Osmix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conveyal/osmix.git"
  },
  "type": "module",
  "main": "./src/fixtures.ts",
  "exports": {
    ".": "./src/fixtures.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@osmix/shared": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
